#!/usr/bin/env bpftrace
// packet_drops.bt
// Traces kernel packet drop events via kfree_skb.
// Uses numeric constants for older bpftrace compatibility.

BEGIN
{
    printf("%-20s %-30s %s\n", "TIME_NS", "CALLER", "DROP_REASON");
    printf("Tracing packet drops... Ctrl-C to stop.\n");
}

kprobe:kfree_skb
{
    $reason = (uint32)arg1;
    // reason > 1 means an actual drop (not a normal free)
    if ($reason > 1) {
        printf("%-20lu %-30s %d\n", nsecs, func, $reason);
    }
}
