#!/usr/bin/env bpftrace
// packet_drops.bt
// Traces kernel packet drop events via kfree_skb.
// Only logs drops with a non-zero reason (real drops, not normal frees).

BEGIN
{
    printf("%-20s %-30s %s\n", "TIME_NS", "CALLER", "DROP_REASON");
    printf("Tracing packet drops... Ctrl-C to stop.\n");
}

kprobe:kfree_skb
{
    $reason = (uint32)arg1;
    if ($reason > 1) {
        printf("%-20lu %-30s %d\n", nsecs, func, $reason);
    }
}
